{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "obsidian": {
      "type": "local",
      "command": [
        "npx",
        "@bitbonsai/mcpvault",
        "D:\\my-note"
      ],
      "enabled": true,
      "timeout": 300000
    },
    "notebooklm": {
      "type": "local",
      "command": [
        "notebooklm-mcp"
      ],
      "enabled": true,
      "timeout": 300000
    },
    "playwright": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@playwright/mcp"
      ],
      "enabled": true,
      "timeout": 300000
    },
    "open-computer-use": {
      "type": "local",
      "command": [
        "open-computer-use",
        "mcp"
      ],
      "enabled": true,
      "timeout": 300000
    }
  },
  "experimental": {
    "mcp_timeout": 300000
  }
}
